  if (name === 'radar') { radarVisible = !radarVisible; document.querySelector('#miniRadar')?.classList.toggle('v9-hidden', !radarVisible); document.querySelector('#distanceRuler')?.classList.toggle('v9-hidden', !radarVisible); }
