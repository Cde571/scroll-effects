const coreUniforms = {
  uTime: { value: 0 },
  uReveal: { value: 0 },
  uEnergy: { value: 0.35 },
  uTint: { value: new THREE.Color(0x62e8ff) },
  uWire: { value: 0 }
};
const coreMaterial = new THREE.ShaderMaterial({
  uniforms: coreUniforms,
  vertexShader: `
    varying vec2 vUv;
    varying vec3 vNormal;
    varying vec3 vWorld;
    void main(){
      vUv = uv;
      vNormal = normalize(normalMatrix * normal);
      vec4 world = modelMatrix * vec4(position, 1.0);
      vWorld = world.xyz;
      gl_Position = projectionMatrix * viewMatrix * world;
    }
  `,
  fragmentShader: `
    uniform float uTime;
    uniform float uReveal;
    uniform float uEnergy;
    uniform vec3 uTint;
    uniform float uWire;
    varying vec2 vUv;
    varying vec3 vNormal;
    varying vec3 vWorld;
    float grid(vec2 uv, float s){
      vec2 g = abs(fract(uv * s - .5) - .5) / fwidth(uv * s);
      return 1.0 - min(min(g.x,g.y),1.0);
    }
    void main(){
      vec3 viewDir = normalize(cameraPosition - vWorld);
      float fresnel = pow(1.0 - max(dot(viewDir, normalize(vNormal)), 0.0), 2.4);
      float band = smoothstep(uReveal - .18, uReveal, vUv.x) - smoothstep(uReveal, uReveal + .18, vUv.x);
      float scan = .5 + .5 * sin((vUv.y + uTime * .08) * 70.0);
      float latitude = smoothstep(.0,.85,1.0 - abs(vUv.y - .5) * 2.0);
      float wire = grid(vUv, 16.0) * uWire;
      vec3 base = uTint * (.055 + latitude * .18);
      vec3 energy = uTint * (band * (.55 + scan * .38) + fresnel * (.55 + uEnergy * .46));
      vec3 color = base + energy + vec3(wire);
      float alpha = .88 + fresnel * .12;
      gl_FragColor = vec4(color, alpha);
    }
  `,
  transparent: true,
  side: THREE.DoubleSide
});

