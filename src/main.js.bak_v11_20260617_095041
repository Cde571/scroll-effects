    bloomPass.enabled = true; glitchPass.enabled = false; rgbShiftPass.enabled = false; filmPass.enabled = true; afterimagePass.enabled = false; bokehPass.enabled = false; ssaoPass.enabled = false; outlinePass.enabled = true;
    coreUniforms.uWire.value = 0; reducedMotion = false; document.body.classList.remove('reduced-motion');
