  if (name === 'maxfx') { setAllFxPreset('max'); updateFxState(); return; }
  if (name === 'resetfx') { setAllFxPreset('reset'); updateFxState(); return; }
  if (name === 'stars') { starsVisible = !starsVisible; deepStars.visible = nearStars.visible = starsVisible; }
  if (name === 'smoke') { smokeVisible = !smokeVisible; smokeGroup.visible = smokeVisible; }
  if (name === 'portal') { portalVisible = !portalVisible; portalGroup.visible = portalVisible; portalLight.visible = portalVisible; }
