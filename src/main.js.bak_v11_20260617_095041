function toggleFx(name, button) {
  if (name === 'bloom') bloomPass.enabled = !bloomPass.enabled;
  if (name === 'glitch') glitchPass.enabled = !glitchPass.enabled;
  if (name === 'rgb') rgbShiftPass.enabled = !rgbShiftPass.enabled;
  if (name === 'film') filmPass.enabled = !filmPass.enabled;
  if (name === 'after') afterimagePass.enabled = !afterimagePass.enabled;
  if (name === 'bokeh') bokehPass.enabled = !bokehPass.enabled;
