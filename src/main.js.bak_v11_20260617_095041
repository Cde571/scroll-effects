const chapterNames = ['Hero', 'Orbit', 'Shader', 'Portal', 'Horizontal', 'Lab'];
const kineticChapterMeta = [
  { code: '00 / opening transmission', title: 'Cosmic <b>Nexus</b>' },
  { code: '01 / camera rail', title: 'Orbital <b>Drift</b>' },
  { code: '02 / shader reveal', title: 'Core <b>Highlight</b>' },
  { code: '03 / wormhole', title: 'Portal <b>Awakening</b>' },
  { code: '04 / horizontal journey', title: 'Immersive <b>Traverse</b>' },
  { code: '05 / fx laboratory', title: 'Effects <b>Atlas</b>' },
  { code: '06 / launch', title: 'Final <b>Sequence</b>' }
];

function updateKineticTitle(progress, chapter) {
  const p = THREE.MathUtils.clamp(progress, 0, 1);
  const split = THREE.MathUtils.smoothstep(p, 0.015, 0.24);
  const compact = THREE.MathUtils.smoothstep(p, 0.06, 0.30);
  const fade = 1 - THREE.MathUtils.smoothstep(p, 0.11, 0.34);
  const mobile = innerWidth < 900;
  const titleX = mobile ? 0 : -compact * 92;
  const titleY = mobile ? -compact * 32 : -compact * 178;
  const titleScale = mobile ? 1 - compact * .22 : 1 - compact * .58;
  const titleRotate = mobile ? 0 : -compact * 2.8;
  const titleBlur = Math.max(0, (compact - .62) * 4.2);
  document.documentElement.style.setProperty('--title-x', `${titleX.toFixed(2)}px`);
  document.documentElement.style.setProperty('--title-y', `${titleY.toFixed(2)}px`);
  document.documentElement.style.setProperty('--title-scale', titleScale.toFixed(3));
  document.documentElement.style.setProperty('--title-rotate', `${titleRotate.toFixed(2)}deg`);
  document.documentElement.style.setProperty('--title-opacity', Math.max(0, fade).toFixed(3));
  document.documentElement.style.setProperty('--title-blur', `${titleBlur.toFixed(2)}px`);
  document.documentElement.style.setProperty('--title-split', split.toFixed(3));
  document.documentElement.style.setProperty('--title-letter', `${(-0.07 + split * 0.045).toFixed(3)}em`);

  const dockOpacity = THREE.MathUtils.smoothstep(p, 0.075, 0.22) * (1 - THREE.MathUtils.smoothstep(p, 0.92, 1.0) * .28);
  const dockY = 22 - dockOpacity * 22 + Math.sin(p * Math.PI * 5.0) * 5.0;
  const dockRotate = Math.sin(p * Math.PI * 2.0) * .85;
  document.documentElement.style.setProperty('--chapter-title-opacity', dockOpacity.toFixed(3));
  document.documentElement.style.setProperty('--chapter-title-y', `${dockY.toFixed(2)}px`);
  document.documentElement.style.setProperty('--chapter-title-rotate', `${dockRotate.toFixed(2)}deg`);
  document.documentElement.style.setProperty('--chapter-progress', `${Math.round(p * 100)}%`);
  document.body.classList.toggle('title-compact', compact > .28);

  const meta = kineticChapterMeta[chapter] || kineticChapterMeta[kineticChapterMeta.length - 1];
  const nextMeta = kineticChapterMeta[Math.min(kineticChapterMeta.length - 1, chapter + 1)] || meta;
  const local = Math.min(1, Math.max(0, (p * 6) - chapter));
  const phase = local < .5 ? meta : nextMeta;
  kineticTitleDock.querySelector('.kinetic-title-kicker').textContent = phase.code;
  kineticTitleDock.querySelector('.kinetic-title-main').innerHTML = phase.title;
  kineticOrbitWord.textContent = `${phase.code.replace(' / ', ' // ')} // ${Math.round(p * 100)}%`;
}

function syncScroll(progress) {
  scrollProgress = progress;
  scrollPercent.textContent = `${Math.round(progress * 100)}%`;
  cursorProgress.style.strokeDashoffset = String(270 * (1 - progress));
  const chapter = Math.min(5, Math.floor(progress * 6));
  chapterName.textContent = chapterNames[chapter] || 'Final';
  updateChapterRail(chapter);
  updateKineticTitle(progress, chapter);

  const reveal = THREE.MathUtils.smoothstep(progress, .08, .52);
  const portal = THREE.MathUtils.smoothstep(progress, .34, .72);
  const smoke = THREE.MathUtils.smoothstep(progress, .12, .78);
  coreUniforms.uReveal.value = reveal;
  coreUniforms.uEnergy.value = 0.35 + progress * 1.25 + horizontalProgress * 0.65;

  portalGroup.scale.setScalar(0.55 + portal * 2.4);
  portalGroup.rotation.z = progress * Math.PI * 2;
  portalLight.intensity = portalVisible ? portal * (darkGrade ? 5.2 : 10.0) : 0;
  portalGroup.children.forEach((child, i) => {
    if (child.material) child.material.opacity = portal * (0.09 + i * 0.018);
  });
  tunnelGroup.children.forEach((child, i) => {
    child.material.opacity = portal * Math.max(0, 0.18 - i * 0.003);
  });

  smokeGroup.children.forEach((sprite, i) => {
    sprite.material.opacity = smokeVisible ? smoke * sprite.userData.baseOpacity : 0;
    sprite.position.y += Math.sin(performance.now() * 0.0002 + i) * 0.0008;
  });

  const x = Math.sin(progress * Math.PI * 2.2) * (2.5 + progress * 2.2);
  const y = 2.6 - progress * 1.1 + Math.sin(progress * Math.PI) * 0.8;
  const z = 9.5 - progress * 8.0;
  if (!transformControls.dragging) {
    camera.position.lerp(new THREE.Vector3(x, y, z), reducedMotion ? 0.02 : 0.055);
    controls.target.lerp(new THREE.Vector3(0, 0, -portal * 2.2), 0.055);
  }

  if (bloomPass.enabled) bloomPass.strength = (darkGrade ? 0.14 : 0.30) + userGlowAmount * 0.42 + progress * (darkGrade ? 0.10 : 0.22) + horizontalProgress * (darkGrade ? 0.08 : 0.16);
  rgbShiftPass.uniforms.amount.value = portal * (darkGrade ? 0.0022 : 0.005) + (horizontalProgress > .75 ? (darkGrade ? .0015 : .0035) : 0);
  afterimagePass.enabled = portal > .55 || afterimagePass.enabled;
  if (progress < .32 && !document.querySelector('[data-fx="after"]')?.classList.contains('active')) afterimagePass.enabled = false;

  drawSequence(progress);
  drawRadar(progress);
}

function drawSequence(progress) {
  const ctx = sequenceCanvas.getContext('2d');
  const w = sequenceCanvas.width;
  const h = sequenceCanvas.height;
  ctx.clearRect(0, 0, w, h);
  const g = ctx.createLinearGradient(0, 0, w, 0);
  g.addColorStop(0, '#07101f');
  g.addColorStop(1, '#071a25');
  ctx.fillStyle = g;
  ctx.fillRect(0, 0, w, h);
  ctx.strokeStyle = 'rgba(143,232,255,.25)';
  ctx.beginPath();
  for (let x = 0; x < w; x++) {
    const t = x / w;
    const y = h * .5 + Math.sin(t * Math.PI * 8 + progress * Math.PI * 4) * 20 * (0.4 + progress);
    if (x === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
  }
  ctx.stroke();
  for (let i = 0; i < 26; i++) {
    const x = (i / 25) * w;
    const active = i / 25 < progress;
    ctx.fillStyle = active ? '#8fe8ff' : 'rgba(143,232,255,.16)';
    ctx.fillRect(x, h - 18, 8, active ? -34 : -12);
  }
}

function drawRadar(progress) {
  const ctx = radarCanvas.getContext('2d');
  const w = radarCanvas.width;
  const c = w / 2;
  ctx.clearRect(0, 0, w, w);
  ctx.strokeStyle = 'rgba(143,232,255,.16)';
  ctx.lineWidth = 1;
  for (let r = 22; r <= 66; r += 22) {
    ctx.beginPath();
    ctx.arc(c, c, r, 0, Math.PI * 2);
    ctx.stroke();
  }
  ctx.strokeStyle = 'rgba(143,232,255,.38)';
  const a = progress * Math.PI * 2;
  ctx.beginPath();
  ctx.moveTo(c, c);
  ctx.lineTo(c + Math.cos(a) * 66, c + Math.sin(a) * 66);
  ctx.stroke();
  ctx.fillStyle = '#8fe8ff';
  for (let i = 0; i < 18; i++) {
    const aa = i * 1.71 + progress * 2;
    const rr = 10 + ((i * 19) % 58);
    ctx.globalAlpha = 0.35 + ((i % 5) / 5) * 0.5;
    ctx.beginPath();
    ctx.arc(c + Math.cos(aa) * rr, c + Math.sin(aa) * rr, 2, 0, Math.PI * 2);
    ctx.fill();
  }
  ctx.globalAlpha = 1;
}

function initScroll() {
  gsap.registerPlugin(ScrollTrigger);
  const lenis = window.Lenis ? new window.Lenis({ smoothWheel: true, lerp: 0.075 }) : null;
  if (lenis) {
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time) => lenis.raf(time * 1000));
    gsap.ticker.lagSmoothing(0);
  }

  ScrollTrigger.create({
    trigger: document.body,
    start: 'top top',
    end: 'bottom bottom',
    scrub: true,
    onUpdate: (self) => syncScroll(self.progress)
  });

  const track = document.querySelector('.horizontal-track');
  const panels = gsap.utils.toArray('.h-panel');
  const horizontalTween = gsap.to(track, {
    x: () => -(track.scrollWidth - innerWidth),
    ease: 'none',
    scrollTrigger: {
      trigger: '#horizontal',
      start: 'top top',
      end: () => `+=${track.scrollWidth - innerWidth}`,
      scrub: 1,
      pin: true,
      anticipatePin: 1,
      invalidateOnRefresh: true,
      onUpdate: (self) => {
        horizontalProgress = self.progress;
        coreGroup.rotation.y = self.progress * Math.PI * 2.0;
        portalLight.intensity = portalVisible ? ((darkGrade ? 2.0 : 5.0) + self.progress * (darkGrade ? 4.5 : 9.0)) : 0;
      }
    }
  });

  panels.forEach((panel, index) => {
    ScrollTrigger.create({
      trigger: panel,
      containerAnimation: horizontalTween,
      start: 'left center',
      end: 'right center',
      onEnter: () => activateHorizontal(index),
      onEnterBack: () => activateHorizontal(index)
    });
  });
}

function activateHorizontal(index) {
  const colors = [0x62e8ff, 0x8fe8ff, 0xffce62, 0x9d7cff, 0x7af7d4];
  coreUniforms.uTint.value.setHex(colors[index] || 0x62e8ff);
  if (index === 1) {
    bloomPass.strength = darkGrade ? 0.42 : 0.95;
    afterimagePass.enabled = true;
  }
  if (index === 2) coreUniforms.uWire.value = 0.35;
  if (index === 3) filmPass.enabled = true;
  if (index === 4) {
    rgbShiftPass.enabled = true;
    glitchPass.enabled = true;
    setTimeout(() => { if (!document.querySelector('[data-fx="glitch"]')?.classList.contains('active')) glitchPass.enabled = false; }, 900);
  }
  updateFxState();
}

function animate() {
  const delta = Math.min(clock.getDelta(), 0.05);
  const t = clock.elapsedTime;
  coreUniforms.uTime.value = t;
  if (glbMixer) glbMixer.update(delta);

  deepStars.userData.starMaterial.uniforms.uTime.value = t;
  nearStars.userData.starMaterial.uniforms.uTime.value = t;
  deepStars.rotation.y += delta * 0.014;
  nearStars.rotation.y -= delta * 0.026;
  smokeGroup.rotation.y += delta * 0.018;
  coreGroup.rotation.x = Math.sin(t * 0.38) * 0.08;
  coreGroup.rotation.y += delta * (0.18 + horizontalProgress * 0.35);
  ringGroup.children.forEach((ring, i) => {
    ring.rotation.z += delta * (0.22 + i * 0.055);
    ring.rotation.x += delta * 0.02;
  });
  arcGroup.children.forEach((arc, i) => {
    arc.material.opacity = 0.12 + 0.18 * (0.5 + 0.5 * Math.sin(t * 1.8 + i));
  });
  asteroids.rotation.y += delta * 0.035;
  lod.rotation.y += delta * 0.4;
  portalGroup.children.forEach((child, i) => {
    child.rotation.z += delta * (0.08 + i * 0.03);
  });

  raycaster.setFromCamera(pointer, camera);
  const hits = raycaster.intersectObjects(selectedObjects, true);
  hoverObject = hits[0]?.object || null;
  if (hoverObject) cursorLabel.textContent = 'VIEW';
  else if (!transformControls.dragging) cursorLabel.textContent = 'SCROLL';

  const d = camera.position.distanceTo(coreGroup.position).toFixed(2);
  document.querySelector('#distanceRuler strong').textContent = `${d} u`;

  controls.update();
  composer.render(delta);
  labelRenderer.render(scene, camera);
}
renderer.setAnimationLoop(animate);

function resize() {
  camera.aspect = innerWidth / innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(innerWidth, innerHeight);
  labelRenderer.setSize(innerWidth, innerHeight);
  composer.setSize(innerWidth, innerHeight);
  outlinePass.resolution.set(innerWidth, innerHeight);
  ssaoPass.setSize(innerWidth, innerHeight);
  smaaPass.setSize(innerWidth * renderer.getPixelRatio(), innerHeight * renderer.getPixelRatio());
  deepStars.userData.starMaterial.uniforms.uPixelRatio.value = renderer.getPixelRatio();
  nearStars.userData.starMaterial.uniforms.uPixelRatio.value = renderer.getPixelRatio();
  ScrollTrigger.refresh();
}
window.addEventListener('resize', resize);

setAllFxPreset('reset');
syncScroll(getPageProgress());
drawSequence(0);
drawRadar(0);
initScroll();

