document.querySelector('#loadGlbBtn')?.addEventListener('click', () => {
  assetStatus.textContent = 'Cargando assets/models/model.glb ...';
  gltfLoader.load('./assets/models/model.glb', (gltf) => {
    if (glbRoot) scene.remove(glbRoot);
    glbRoot = gltf.scene;
    glbRoot.position.set(0, -0.25, 0);
    glbRoot.scale.setScalar(1.25);
    scene.add(glbRoot);
    selectedObject = glbRoot;
    selectedObjects.push(glbRoot);
    outlinePass.selectedObjects = [glbRoot];
    if (gltf.animations.length) {
      glbMixer = new THREE.AnimationMixer(glbRoot);
      for (const clip of gltf.animations) glbMixer.clipAction(clip).play();
    }
    transformControls.attach(glbRoot);
    assetStatus.textContent = `GLB cargado: ${gltf.animations.length} animación(es).`;
  }, (progress) => {
    if (progress.total) assetStatus.textContent = `Cargando GLB: ${Math.round(progress.loaded / progress.total * 100)}%`;
  }, (error) => {
    assetStatus.textContent = 'No se encontró assets/models/model.glb. Exporta desde Blender como GLB y colócalo en esa ruta.\n' + error.message;
  });
});

document.querySelector('#assetCheckBtn')?.addEventListener('click', async () => {
  const checks = ['./assets/models/model.glb', './assets/textures/studio.hdr', './assets/video/demo.mp4', './assets/lottie/animation.json'];
  const lines = [];
  for (const path of checks) {
    try {
      const response = await fetch(path, { method: 'HEAD' });
      lines.push(`${response.ok ? 'OK ' : 'NO '} ${path}`);
    } catch {
      lines.push(`NO ${path}`);
    }
  }
