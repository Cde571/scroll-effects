function createGridHelper() {
  const group = new THREE.Group();
  for (let r = 2; r <= 14; r += 2) {
    const pts = [];
    for (let i = 0; i <= 128; i++) {
      const a = i / 128 * Math.PI * 2;
      pts.push(new THREE.Vector3(Math.cos(a) * r, -1.9, Math.sin(a) * r));
    }
    const line = new THREE.Line(new THREE.BufferGeometry().setFromPoints(pts), new THREE.LineBasicMaterial({ color: 0x356c86, transparent: true, opacity: 0.12 }));
    group.add(line);
  }
  return group;
}
