const listener = new THREE.AudioListener();
camera.add(listener);
let audioNodes = null;
function initAudio() {
  if (audioNodes) return audioNodes;
  const context = listener.context;
  const master = context.createGain();
  master.gain.value = 0;
  const filter = context.createBiquadFilter();
  filter.type = 'lowpass';
  filter.frequency.value = 470;
  const oscA = context.createOscillator();
  const oscB = context.createOscillator();
  oscA.type = 'sine';
  oscB.type = 'triangle';
  oscA.frequency.value = 54;
  oscB.frequency.value = 82;
  const gainA = context.createGain();
  const gainB = context.createGain();
  gainA.gain.value = .55;
  gainB.gain.value = .12;
  oscA.connect(gainA).connect(filter).connect(master).connect(context.destination);
  oscB.connect(gainB).connect(filter);
  oscA.start();
  oscB.start();
  audioNodes = { context, master, filter, oscA, oscB };
  return audioNodes;
}

document.querySelector('#audioBtn')?.addEventListener('click', async () => {
  const nodes = initAudio();
  await nodes.context.resume();
  audioOn = !audioOn;
  nodes.master.gain.setTargetAtTime(audioOn ? 0.018 : 0, nodes.context.currentTime, 0.12);
  document.querySelector('#audioBtn').textContent = audioOn ? 'Audio ON' : 'Audio OFF';
});

