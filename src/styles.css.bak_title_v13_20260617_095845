.horizontal-section{position:relative;z-index:30;height:100vh;overflow:hidden;display:flex;align-items:center}.horizontal-track{display:flex;height:100%;width:max-content}.h-panel{width:100vw;min-width:100vw;height:100vh;padding:22vh 10vw 18vh;display:flex;flex-direction:column;justify-content:center;align-items:flex-start;background:linear-gradient(90deg,rgba(2,4,10,.18),rgba(2,4,10,.04));border-left:1px solid rgba(150,210,255,.06)}.h-panel h2{max-width:700px}.h-panel p{max-width:560px}.h-panel:nth-child(even){align-items:flex-end;text-align:right;background:linear-gradient(90deg,rgba(2,4,10,.02),rgba(2,4,10,.20))}
