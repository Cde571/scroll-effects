@media(max-width:900px){.nav{display:none}.hero-copy{width:calc(100vw - 42px);left:22px}.hero-copy h1{font-size:clamp(42px,13vw,72px)}.lead{max-width:92vw}.story-note,.story-note.left,.story-note.right,.story-note.center{width:calc(100vw - 42px);margin-left:22px;margin-right:22px;text-align:left}.fx-grid{grid-template-columns:repeat(2,1fr)}.material-panel{right:12px;left:12px;bottom:82px;width:auto}.mini-radar,.distance-ruler{display:none}.chapter-rail{display:none}.doc-hud{left:12px;right:12px;justify-content:space-between}.cursor-ring{display:none}}


/* V9 Dark Full corrections: less glow, restored effects atlas */
body.v9-dark-grade #webgl{filter:brightness(.72) contrast(1.08) saturate(.86)}
body.v9-dark-grade .hero-copy, body.v9-dark-grade .material-panel, body.v9-dark-grade .doc-hud, body.v9-dark-grade .topbar{filter:brightness(.96)}
.dark-control{position:fixed;right:22px;top:84px;z-index:72;display:flex;align-items:center;gap:10px;padding:10px 12px;border:1px solid rgba(150,210,255,.14);border-radius:999px;background:rgba(1,3,8,.62);backdrop-filter:blur(16px);box-shadow:0 20px 60px rgba(0,0,0,.45)}
.dark-control span{font-size:9px;letter-spacing:.22em;text-transform:uppercase;color:rgba(225,235,255,.52)}
.dark-control input{width:110px;accent-color:var(--cyan)}
.dark-control button{border:1px solid rgba(150,210,255,.20);background:rgba(5,9,18,.52);color:#fff;border-radius:999px;padding:7px 10px;font-size:10px;letter-spacing:.14em;text-transform:uppercase;cursor:pointer}
.effects-atlas-section{position:relative;z-index:32;min-height:140vh;display:grid;place-items:center;padding:12vh 0;pointer-events:auto}.effects-atlas-shell{width:min(1180px,90vw);border-left:1px solid rgba(143,232,255,.18);border-right:1px solid rgba(143,232,255,.08);padding:34px clamp(18px,3.4vw,52px);background:linear-gradient(90deg,rgba(1,4,10,.75),rgba(4,10,20,.34),rgba(1,4,10,.62));backdrop-filter:blur(18px);border-radius:28px;box-shadow:0 40px 130px rgba(0,0,0,.68)}.effects-atlas-shell h2{font-size:clamp(36px,5.4vw,88px);line-height:.9;margin:0 0 18px;text-transform:uppercase;letter-spacing:-.055em}.atlas-lead{max-width:860px;color:rgba(225,235,255,.72);line-height:1.75}.effect-constellation{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:22px 28px;margin-top:28px}.effect-cluster{position:relative;padding-top:16px}.effect-cluster:before{content:"";position:absolute;left:0;right:0;top:0;height:1px;background:linear-gradient(90deg,rgba(143,232,255,.36),transparent)}.effect-cluster h3{font-size:12px;letter-spacing:.24em;text-transform:uppercase;color:var(--cyan);margin:0 0 14px}.effect-cluster ol{list-style:none;margin:0;padding:0;display:grid;gap:8px}.effect-cluster li{display:grid;grid-template-columns:34px 1fr auto;align-items:center;gap:10px;min-height:30px;color:rgba(232,240,255,.72);font-size:13px}.effect-cluster li b{font-size:10px;color:rgba(143,232,255,.58);font-weight:900}.effect-cluster li span{border-bottom:1px dotted rgba(143,232,255,.12);padding-bottom:3px}.effect-cluster li em{font-style:normal;font-size:9px;letter-spacing:.16em;color:rgba(122,247,212,.72);border:1px solid rgba(122,247,212,.18);border-radius:999px;padding:4px 7px;background:rgba(3,12,16,.28)}.effect-cluster li em:nth-child(3){white-space:nowrap}.v9-muted-light .label{opacity:.68}.v9-hidden{display:none!important}
@media(max-width:1100px){.effect-constellation{grid-template-columns:repeat(2,minmax(0,1fr))}.fx-grid.expanded{grid-template-columns:repeat(4,minmax(0,1fr));max-height:360px}}
@media(max-width:760px){.effect-constellation{grid-template-columns:1fr}.dark-control{right:12px;top:72px}.dark-control input{width:74px}.fx-grid.expanded{grid-template-columns:repeat(2,minmax(0,1fr))}}


/* V10 Kinetic Title System: el título ya no queda estático */
:root{
  --title-x: 0px;
  --title-y: 0px;
  --title-scale: 1;
  --title-rotate: 0deg;
  --title-opacity: 1;
  --title-blur: 0px;
  --title-split: 0;
  --title-letter: -0.07em;
  --chapter-title-opacity: 0;
  --chapter-title-y: 18px;
  --chapter-title-rotate: 0deg;
  --chapter-progress: 0%;
}
.hero-copy{
  transform: translate3d(var(--title-x), var(--title-y), 0) scale(var(--title-scale)) rotate(var(--title-rotate));
  transform-origin: left top;
  opacity: var(--title-opacity);
  filter: blur(var(--title-blur));
  will-change: transform, opacity, filter;
}
.hero-copy h1{
  letter-spacing: var(--title-letter);
  will-change: letter-spacing;
}
.hero-copy h1 span{
  transition: none;
  will-change: transform, opacity, filter;
}
.hero-copy h1 span:nth-child(1){
  transform: translate3d(calc(var(--title-split) * -74px), calc(var(--title-split) * -12px), 0) rotate(calc(var(--title-split) * -2.5deg));
}
.hero-copy h1 span:nth-child(2){
  transform: translate3d(calc(var(--title-split) * 62px), calc(var(--title-split) * 5px), 0) rotate(calc(var(--title-split) * 1.8deg));
}
.hero-copy h1 span:nth-child(3){
  transform: translate3d(calc(var(--title-split) * -28px), calc(var(--title-split) * 18px), 0) rotate(calc(var(--title-split) * .9deg));
}
.kinetic-title-dock{
  position: fixed;
  z-index: 58;
  top: 86px;
  left: 50%;
  transform: translate3d(-50%, var(--chapter-title-y), 0) rotate(var(--chapter-title-rotate));
  opacity: var(--chapter-title-opacity);
  pointer-events: none;
  width: min(720px, calc(100vw - 52px));
  text-align: center;
  will-change: transform, opacity;
  filter: drop-shadow(0 18px 45px rgba(0,0,0,.55));
}
.kinetic-title-dock::before{
  content:"";
  position:absolute;
  left:50%;
  top:-16px;
  transform:translateX(-50%);
  width:min(420px, 60vw);
  height:1px;
  background:linear-gradient(90deg,transparent,rgba(143,232,255,.55),transparent);
}
.kinetic-title-kicker{
  display:block;
  margin-bottom: 8px;
  color: rgba(143,232,255,.76);
  font-size: 10px;
  letter-spacing: .32em;
  text-transform: uppercase;
  font-weight: 900;
}
.kinetic-title-main{
  display:block;
  font-size: clamp(24px, 4.8vw, 72px);
  line-height: .86;
  letter-spacing: -.055em;
  text-transform: uppercase;
  font-weight: 900;
  color: rgba(246,250,255,.92);
}
.kinetic-title-main b{
  color: var(--cyan);
  font-weight: 900;
  text-shadow: 0 0 18px rgba(143,232,255,.18);
}
.kinetic-title-dock .chapter-meter{
  display:block;
  width:min(360px, 54vw);
  height:2px;
  margin: 14px auto 0;
  background: rgba(143,232,255,.10);
  overflow:hidden;
  border-radius:999px;
}
.kinetic-title-dock .chapter-meter i{
  display:block;
  width: var(--chapter-progress);
  height:100%;
  background: linear-gradient(90deg, rgba(122,247,212,.35), rgba(143,232,255,.85));
  box-shadow: 0 0 18px rgba(143,232,255,.34);
}
.kinetic-orbit-word{
  position: fixed;
  z-index: 57;
  right: clamp(22px, 5vw, 72px);
  top: 28vh;
  pointer-events:none;
  transform: translate3d(0, calc(var(--title-split) * 120px), 0) rotate(90deg);
  transform-origin:right center;
  opacity: calc(var(--chapter-title-opacity) * .62);
  color: rgba(226,238,255,.48);
  font-size: 10px;
  letter-spacing: .38em;
  text-transform: uppercase;
  font-weight: 900;
}
.title-motion-hint{
  position: fixed;
  z-index: 58;
  left: clamp(22px, 5vw, 84px);
  top: clamp(72px, 9vh, 110px);
  pointer-events:none;
  opacity: calc(1 - min(var(--title-split), 1));
  color: rgba(226,238,255,.45);
  font-size: 10px;
  letter-spacing:.24em;
  text-transform: uppercase;
}
.title-motion-hint::before{
  content:"";
  display:inline-block;
  width:34px;
  height:1px;
  margin-right:10px;
  vertical-align:middle;
  background:rgba(143,232,255,.42);
}
body.title-compact .brand span:last-of-type{
  color: var(--cyan);
}
body.title-compact .topbar{
  box-shadow: 0 0 46px rgba(0,0,0,.72), 0 0 24px rgba(143,232,255,.04);
}
@media(max-width:900px){
  .kinetic-title-dock{top:74px;width:calc(100vw - 36px)}
  .kinetic-title-main{font-size:clamp(22px,9vw,48px)}
  .kinetic-orbit-word,.title-motion-hint{display:none}
  .hero-copy h1 span:nth-child(1),
  .hero-copy h1 span:nth-child(2),
  .hero-copy h1 span:nth-child(3){transform:none}
}
