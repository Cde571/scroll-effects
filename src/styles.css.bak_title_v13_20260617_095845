.material-panel{position:fixed;right:clamp(18px,4vw,68px);bottom:84px;z-index:55;width:min(390px,calc(100vw - 36px));padding:18px;border:1px solid rgba(150,210,255,.18);border-radius:26px;background:rgba(5,9,18,.44);backdrop-filter:blur(18px)}.panel-top{display:flex;justify-content:space-between;gap:12px;align-items:center;margin-bottom:13px}.panel-top span{color:rgba(220,235,255,.56);font-size:10px;letter-spacing:.16em;text-transform:uppercase}.panel-top strong{font-size:12px}.swatches{display:flex;gap:10px;flex-wrap:wrap}.swatches button{width:42px;height:42px;border-radius:14px;border:1px solid rgba(255,255,255,.18);background:radial-gradient(circle at 30% 28%,#fff9,var(--sw));cursor:pointer}.swatches button.active{outline:2px solid var(--cyan);box-shadow:0 0 24px color-mix(in srgb,var(--sw),transparent 25%)}.material-panel p{margin:12px 0 0;color:rgba(226,238,255,.64);font-size:13px;line-height:1.6}
.doc-hud{position:fixed;right:22px;bottom:18px;z-index:60;display:flex;align-items:center;gap:18px;padding:12px 16px;border:1px solid rgba(150,210,255,.16);background:rgba(5,9,18,.62);backdrop-filter:blur(18px);border-radius:20px}.doc-hud div{display:flex;flex-direction:column}.doc-hud strong{font-size:18px}.doc-hud span{font-size:9px;text-transform:uppercase;letter-spacing:.16em;color:rgba(225,235,255,.52)}.bars{flex-direction:row!important;gap:4px;align-items:flex-end}.bars i{display:block;width:5px;background:linear-gradient(var(--cyan),transparent);border-radius:99px;height:16px}.bars i:nth-child(2){height:25px}.bars i:nth-child(3){height:36px}.bars i:nth-child(4){height:20px}
.chapter-rail{position:fixed;z-index:50;left:22px;top:50%;transform:translateY(-50%);display:flex;flex-direction:column;gap:15px}.chapter-rail::before{content:"";position:absolute;left:50%;top:-36px;bottom:-36px;width:1px;background:linear-gradient(transparent,rgba(143,232,255,.24),transparent)}.chapter-rail span{position:relative;display:grid;place-items:center;width:34px;height:34px;border-radius:50%;border:1px solid rgba(150,210,255,.14);background:rgba(5,9,18,.34);font-size:10px;color:rgba(225,235,255,.48)}.chapter-rail span.active{color:#fff;border-color:rgba(143,232,255,.62);box-shadow:0 0 22px rgba(143,232,255,.18)}
